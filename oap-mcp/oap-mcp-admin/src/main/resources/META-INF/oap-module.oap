name = oap-mcp-admin
dependsOn = [oap-ws-admin-ws, oap-mcp]

services {
  mcp-log {
    implementation = oap.mcp.admin.McpLog
    parameters {
      logWS = <modules.oap-ws-admin-ws.ws-log>
    }
    link.tools = <modules.oap-mcp.mcp-service>
  }
  mcp-jpath {
    implementation = oap.mcp.admin.McpJPath
    parameters {
      jPathWS = <modules.oap-ws-admin-ws.ws-jpath>
    }
    link.tools = <modules.oap-mcp.mcp-service>
  }
}
